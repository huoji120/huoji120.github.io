{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u4e8c\u8fdb\u5236\u65b0\u624b\u5165\u95e8","text":"<p>\u6b22\u8fce\u6765\u5230\u6587\u6863\u7ad9\u70b9\uff01\u8fd9\u4e2a\u662f\u7528\u6765\u505a\u4e8c\u8fdb\u5236\u5165\u95e8\u7684\u5b66\u4e60\u7f51\u7ad9</p> <p>\u9ad8\u7ea7\u6280\u672f\u53ef\u4ee5\u53ef\u4ee5\u53c2\u8003: https://key08.com/</p>"},{"location":"crackme/","title":"CrackMe","text":"<p>\u8fd9\u91cc\u662f CrackMe \u5b66\u4e60\u76ee\u5f55\u3002</p> <ul> <li>\u6211\u7684\u6587\u7ae0</li> </ul>"},{"location":"crackme/cpp-no-pack-keygenme-crackme/","title":"\u96f6\u7f16\u7a0b\u57fa\u7840\u9006\u5411\u7834\u89e3\u6b64crack\u8fc7\u7a0b\u8bb0\u5f55","text":"<p>\u524d\u60c5\u63d0\u8981\uff1a \u4f7f\u7528\u5230\u7684\u5de5\u5177\u6709\uff1aIDA\u3001X64dbg \u8fd9\u4e2acrackme\u7684\u5730\u5740 https://www.52pojie.cn/thread-1921178-1-1.html</p>"},{"location":"crackme/cpp-no-pack-keygenme-crackme/#_1","title":"\u601d\u8def","text":"<p>\u901a\u8fc7\u95ee\u8be2AI\u53ef\u4ee5\u77e5\u9053\uff0c\u7834\u89e3\u6709\u4e24\u6761\u8def\uff1a1\u3001\u5f3a\u884c\u4fee\u6539\u8df3\u8f6c\uff0c2\u3001\u627e\u5230\u5bc6\u7801\u3002\u5148\u6765\u770b\u770b\u5982\u4f55\u5f3a\u884c\u4fee\u6539\u8df3\u8f6c\u5427\u3002</p>"},{"location":"crackme/cpp-no-pack-keygenme-crackme/#_2","title":"\u65b9\u6cd5\u4e00\uff1a\u5f3a\u884c\u4fee\u6539\u8df3\u8f6c","text":""},{"location":"crackme/cpp-no-pack-keygenme-crackme/#_3","title":"\u4e00\u3001\u4e0b\u8f7d\u5de5\u5177","text":""},{"location":"crackme/cpp-no-pack-keygenme-crackme/#1ida","title":"1.\u4e0b\u8f7dIDA","text":"<p>\u8fd9\u4e2a\u6211\u76f4\u63a5\u53bb52pojie\u4e0a\u627e\u7136\u540e\u4e0b\u8f7d\u7684</p>"},{"location":"crackme/cpp-no-pack-keygenme-crackme/#2x64dbg","title":"2.\u4e0b\u8f7dx64dbg","text":"<p>\u53bb\u8c37\u6b4c\u641c\u7d22x64dbg\uff0c\u8fdb\u5165\u5b98\u7f51https://x64dbg.com/\uff0c \u7136\u540e\u70b9\u51fb\u4e0b\u8f7d\u5c31\u5b8c\u4e8b\u513f\u4e86\uff01</p> <p>\u5bf9\u4e86\uff0c\u8fd8\u6709\u4e00\u4e2a\u91cd\u8981\u7684\u5de5\u5177\u5c31\u662fAI\uff0c\u6211\u90fd\u662f\u95eeAI\u544a\u8bc9\u6211\u600e\u4e48\u505a\u7684\u3002 \u51c6\u5907\u5b8c\u6bd5\uff0c\u5f00\u59cb\u7740\u624b\u5427\uff01</p>"},{"location":"crackme/cpp-no-pack-keygenme-crackme/#ida","title":"\u4e8c\u3001\u7528IDA\u8fdb\u884c\u9759\u6001\u5206\u6790","text":"<p>PS \u6ce8\u610f\uff0c\u8fd9\u91cc\u8bf4\u4e00\u4e0bIDA\u662f\u5e72\u5565\u7684\uff1aIDA \u662f\u4e00\u4e2a\uff1a\u9759\u6001\u5206\u6790\u5de5\u5177\uff0c\u5b83\u4e0d\u8fd0\u884c\u7a0b\u5e8f\uff0c\u53ea\u5206\u6790\u4ee3\u7801\u7ed3\u6784\u3002\u6211\u4eec\u53ef\u4ee5\u7528\u5b83\u6765\u770b\u51fd\u6570\u903b\u8f91\u3001\u627e\u5173\u952e\u5b57\u7b26\u4e32\u3001\u770b\u6d41\u7a0b\u56fe\uff08\u7a0b\u5e8f\u7ed3\u6784\uff09\u4ece\u800c\u6765\u8fdb\u884c\u9006\u5411\u5206\u6790\u3002</p> <p>\u6253\u5f00IDA\u2014\u2014&gt;\u70b9\u51fbok\u2014\u2014&gt;\u70b9\u51fbnew\uff0c\u5f00\u59cb\u65b0\u9879\u76ee\uff0c\u627e\u5230\u8981\u5206\u6790\u7684\u6587\u4ef6crackme.exe\u5e76\u6253\u5f00\uff08\u4e5f\u53ef\u4ee5\u76f4\u63a5\u62d6\u8fdb\u53bb\uff09\uff0c\u4f1a\u5f39\u51faload a new file\u7684\u5f39\u7a97\uff0c\u76f4\u63a5\u70b9ok\uff0c\u7b49\u5f85\u5176\u81ea\u52a8\u5206\u6790\u5b8c\u6bd5\uff0c\u9875\u9762\u4e0b\u65b9output\u6846\u4f1a\u663e\u793a\uff1a<code>The initial autoanalysis has been finished.</code>\u5c31\u662f\u521d\u6b65\u5206\u6790\u5b8c\u6bd5\u3002</p> <p>\u76f4\u63a5\u8fdb\u5165\u773c\u5e18\u7684\u5c31\u662f\u4e00\u4e2a\u6d41\u7a0b\u56fe\u4e00\u6837\u7684\u9875\u9762\u5373\u53cd\u6c47\u7f16\u89c6\u56fe\uff0c </p> <p>\u6309\u4f4f<code>shift</code>+<code>f12</code>,\u6253\u5f00\u5b57\u7b26\u4e32\u7a97\u53e3,\u627e\u5230\u7c7b\u4f3c\"Correct\"\u3001\"Wrong\"\u3001\"Success\"\u3001\"Fail\"\u3001\"Password\"\u7684\u5b57\u773c\uff0c\u53cc\u51fb </p> <p>\u53cc\u51fb\u4e4b\u540e\u8fdb\u5165\uff0c\u53ef\u4ee5\u770b\u5230\u8fd9\u4e00\u884c\uff1a<code>rdata:00440043 aWrongTryAgian  db 'wrong! try agian! ',0</code> \u6309<code>x\u952e</code>\uff0c\u770b\u770b\u662f\u54ea\u91cc\u5f15\u7528 </p> <p>\u6309\u4e0b<code>x\u952e</code>\u4e4b\u540e\uff0c\u53ef\u80fd\u8df3\u8f6c\u5230\u53cd\u6c47\u7f16\u56fe\u5f62\u89c6\u56fe\u6216\u8005\u662f\u53cd\u6c47\u7f16\u5217\u8868\u89c6\u56fe\uff0c\u5982\u679c\u8df3\u8f6c\u5230\u56fe\u5f62\u89c6\u56fe\u53ef\u4ee5\u6309\u4e0b\u7a7a\u683c\u952e\u770b\u5217\u8868\u89c6\u56fe  </p> <p>\u5728\u5217\u8868\u89c6\u56fe\u4e2d\uff0c\u53ef\u4ee5\u770b\u5230\u8fd9\u4e2a\u4f4d\u7f6e</p> <pre><code>.text:004015AF loc_4015AF:                             ; CODE XREF: _main+1F7\u2191j\n\n.text:004015AF                 mov     [esp+0C8h+var_C4], offset aWrongTryAgian ; \"wrong! try agian! \"\n</code></pre> <p>\u8fd9\u4e2a\u5730\u65b9\u5c31\u662f\u8f93\u5165\u9519\u8bef\u5bc6\u7801\u5f39\u51fa\u201cwrong! try agian!\u201d\u4e4b\u5904\uff0c\u90a3\u4e48\u6211\u4eec\u5f80\u4e0a\u627e\u5c31\u80fd\u627e\u5230\u5bf9\u6bd4\u5bc6\u7801\u5224\u65ad\u8f93\u5165\u5bc6\u7801\u6b63\u786e\u4e0e\u5426\u7684\u5730\u65b9\uff1a<code>.text:00401587                 jz      short loc_4015AF</code>\uff0c\u8bb0\u4f4f\u8fd9\u4e2a\u5730\u5740\uff1a<code>00401587</code> </p> <p>\u6309\u4e0b<code>F5</code>\uff0c\u770b\u5176\u4f2a\u4ee3\u7801 </p> <p>\u6211\u4eec\u5c31\u53ef\u4ee5\u770b\u5230,\u4ee5\u4e0b\u4ee3\u7801\uff1a</p> <pre><code>if ( (unsigned __int8)std::operator==&lt;char&gt;((std::string *)v14, (std::string *)v15) )\n    v5 = std::operator&lt;&lt;&lt;std::char_traits&lt;char&gt;&gt;((int)&amp;std::cout, \"congratulation! \");\n  else\n    v5 = std::operator&lt;&lt;&lt;std::char_traits&lt;char&gt;&gt;((int)&amp;std::cout, \"wrong! try agian! \");\n</code></pre> <p>\u6309\u7167\u6211\u7684\u7406\u89e3\uff0c\u610f\u601d\u5c31\u7b97\u5c06\u6b63\u786e\u5bc6\u7801\u4e0e\u8f93\u5165\u5bc6\u7801\u8fdb\u884c\u5bf9\u6bd4\uff0c\u5982\u679c\u6b63\u786e\u5c31\u6253\u5370\"congratulation! \"\uff0c\u5982\u679c\u9519\u8bef\u5c31\u6253\u5370\"wrong! try agian! \"\u3002 \u540c\u4e49\uff0c\u5728\u4e0a\u9762\u53cd\u6c47\u7f16\u89c6\u56fe\u91cc\u9762<code>00401587</code>\u8fd9\u4e2a\u5730\u65b9\u5c31\u662f\u5bf9\u6bd4\u5bc6\u7801\uff08\u6b63\u786e\u5c31\u8df3\u8f6c\u5230\"congratulation! \",\u9519\u8bef\u5c31\u8df3\u8f6c\"wrong! try agian! \"\uff09\u7684\u5730\u65b9\u3002</p> <p>PS: je = \u76f8\u7b49\u8df3 jne = \u4e0d\u7b49\u8df3 jz = \u7b49\u4e8e0\u8df3 jnz = \u4e0d\u7b49\u4e8e0\u8df3</p> <p>\u90a3\u4e48\uff0c<code>.text:00401587                 jz      short loc_4015AF</code>\u610f\u601d\u5c31\u662f\u5f53\u7b49\u4e8e0\u65f6\u5c31\u8df3\u8f6c\u5230<code>loc_4015AF</code>,\u90a3\u6211\u4eec\u5c31\u628a<code>jz</code>\u6539\u6210<code>jnz</code>\uff0c\u90a3\u4e0d\u5c31\u662f\u65e0\u8bba\u4f60\u8f93\u5165\u4ec0\u4e48\u90fd\u4e0d\u8df3\u5230\"wrong! try agian! \"\uff0c\u800c\u662f\u8df3\u5230\"congratulation! \"\u4e86\u5417\uff01</p>"},{"location":"crackme/cpp-no-pack-keygenme-crackme/#x64dbg","title":"\u4e09\u3001\u7528x64dbg\u8fdb\u884c\u52a8\u6001\u8c03\u8bd5","text":"<p>\u65e2\u7136\u77e5\u9053\u4e86\u53ef\u80fd\u7834\u89e3\u7684\u5730\u65b9\uff0c\u6211\u4eec\u5c31\u5230x64dbg\u91cc\u9762\u8fdb\u884c\u52a8\u6001\u8c03\u8bd5\uff0c\u8bd5\u8bd5\u770b\u5230\u5e95\u80fd\u4e0d\u80fd\u8fd9\u6837\u5e72\u3002</p>"},{"location":"crackme/cpp-no-pack-keygenme-crackme/#1","title":"1\u3001\u52a8\u6001\u8c03\u8bd5","text":"<p>\u8fd9\u4e2acrack.exe\u662f32\u4f4d\u7684\uff0c\u6211\u4eec\u5c31\u6253\u5f00x32dbg\uff0c\u628a\u5b83\u62d6\u8fdb\u53bb\uff0c\u6309\u4e0b<code>CTRL</code>+<code>G</code>,\u8f93\u5165\u6211\u4eec\u5728IDA\u627e\u5230\u7684\u90a3\u4e2a\u9700\u8981\u6539\u52a8\u7684\u76ee\u6807\u7684\u5730\u5740\uff0c\u5373<code>00401587</code> </p> <p>\u70b9\u51fb\u8fd9\u4e00\u884c<code>00401587 | 74 26                    | je crackme.4015AF                       |</code>\uff0c\u6309\u4e0b<code>\u7a7a\u683c\u952e</code>\uff08\u6216\u662f\u9f20\u6807\u53f3\u952e\u70b9\u9009\u6c47\u7f16\uff09\uff0c\u5c06\u5f39\u6846\u4e2d\u7684<code>jz 0x004015AF</code>\u6539\u4e3a<code>jnz 0x004015AF</code>\u6216\u662f<code>nop</code>\uff0c\u70b9\u51fb<code>\u786e\u5b9a</code>  \u8981\u6ce8\u610f\u7684\u662f\u6539\u4e86\u4e4b\u540e\u4f1a\u7ee7\u7eed\u5f39\u6846\uff0c\u7ed9\u4e0b\u4e00\u4e2a\u5730\u5740\u8fdb\u884c\u4fee\u6539\uff0c\u8fd9\u65f6\u5019\u8981\u70b9\u51fb<code>\u53d6\u6d88</code> </p> <p>\u6539\u540e\uff0c\u70b9\u51fb<code>\u8fd0\u884c</code>(\u6216\u8005\u6309<code>F9</code>\u8fd0\u884c)\uff0c\u968f\u673a\u8f93\u5165\u7528\u6237\u540d\u548c\u5bc6\u7801\uff0c\u770b\u770b\u6548\u679c   \u663e\u793a\"congratulation! \"\u5c31\u662f\u6210\u529f\u7834\u89e3\u4e86\uff01 \u4f46\u662f\uff01\u8fd9\u53ea\u662f\u5728x32dbg\u91cc\u8c03\u8bd5\u8fd0\u884c\u7684\u7ed3\u679c\uff0c\u800c\u4e0d\u662f\u771f\u6b63\u7684\u7834\u89e3\uff0c\u5173\u6389x32dbg\u4e4b\u540e\u518d\u6253\u5f00crack.exe\uff0c\u968f\u673a\u8f93\u5165\u7528\u6237\u540d\u548c\u5bc6\u7801\u4f9d\u65e7\u4f1a\u663e\u793a\"wrong! try agian! \"\u3002\u90a3\u4e48\uff0c\u6211\u4eec\u63a5\u4e0b\u53bb\u5c31\u7ed9\u5b83\u6253\u4e2a\u8865\u4e01\uff0c\u771f\u6b63\u7834\u89e3\u5b83\u3002</p>"},{"location":"crackme/cpp-no-pack-keygenme-crackme/#2","title":"2\u3001\u6253\u8865\u4e01","text":"<p>\u9f20\u6807\u53f3\u952e\uff0c\u70b9\u51fb<code>\u8865\u4e01</code>\uff0c\u4f1a\u5f39\u51fa\u8865\u4e01\u5f39\u6846\uff0c\u70b9\u51fb<code>\u4fee\u8865\u6587\u4ef6</code>\uff0c\u4f1a\u5f39\u51fa\u4fdd\u5b58\u6587\u4ef6\uff0c\u53d6\u540d\u4e3acrack_patched.exe </p> <p>\u73b0\u5728\uff0c\u4f60\u5173\u6389x32dbg\uff0c\u6253\u5f00crack_patched.exe\uff0c\u968f\u673a\u8f93\u5165\u7528\u6237\u540d\u548c\u5bc6\u7801\uff0c\u90fd\u4f1a\u663e\u793a\"congratulation! \" \u5c31\u8fd9\u6837\u5927\u529f\u544a\u6210\uff0c\u96f6\u4ee3\u7801\u57fa\u7840\u7684\u4f60\u5c31\u6210\u529f\u7834\u89e3\u4e86\u8fd9\u4e2acrack.exe\uff0c\u975e\u5e38\u7b80\u5355\uff01</p>"},{"location":"crackme/cpp-no-pack-keygenme-crackme/#_4","title":"\u65b9\u6cd5\u4e8c\uff1a\u627e\u5230\u5bc6\u7801","text":"<p>\u6253\u5f00IDA,\u627e\u5230\u4f2a\u4ee3\u7801\u8fd9\u4e00\u9875\uff0c\u590d\u5236\u7c98\u8d34\u6574\u9875\u4ee3\u7801\u95eeAI\uff0c\u8ba9AI\u89e3\u91ca\u4e00\u4e0b\u8fd9\u4e2a\u4ee3\u7801\u5565\u610f\u601d\uff0c\u5e76\u8ba9AI\u751f\u6210\u4e00\u4e2a\u8f93\u5165\u7528\u6237\u540d\u8ba1\u7b97\u51fa\u5bc6\u7801\u7684python\u6587\u4ef6\u3002  </p> <p>\u590d\u5236\u7c98\u8d34AI\u7ed9\u7684\u4ee3\u7801\u5230VSCode\uff0c\u5e76\u4fdd\u5b58\u3002 </p> <p>\u7136\u540e\u5728\u8be5python\u6587\u4ef6\u5939\u6240\u5728\u7684\u76ee\u5f55\u6253\u5f00cmd\uff0c\u8fd0\u884c\u8be5python\u6587\u4ef6\uff0c\u5c31\u53ef\u4ee5\u7b97\u51fa\uff0c\u968f\u673a\u7528\u6237\u540d\u5bf9\u5e94\u7684\u5bc6\u7801\uff0c\u6253\u5f00crack.exe\u8bd5\u4e00\u4e0b\uff0c\u662f\u5bf9\u7684\u3002  \u8fd9\u6837\u5c31\u627e\u5230\u5bc6\u7801\u4e86\u3002</p>"}]}